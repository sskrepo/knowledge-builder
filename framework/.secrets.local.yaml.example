# Local secrets file for laptop dev — committed as EXAMPLE only.
#
# Copy to: ~/.kbf/secrets.yaml  (or override path with KBF_SECRETS_FILE)
# Then set: export KBF_SECRETS_BACKEND=local
#
# DO NOT commit the populated file. Add ~/.kbf/ to your global gitignore if you
# keep it inside any other git repo.
#
# Format: slug → secret value. Slug names match `vault://kb/<slug>` references
# in your env config + adapter configs.

secrets:
  # ---- Oracle 23ai Autonomous Database ----
  adb-admin-dev:           "<ADB ADMIN password from OCI Console>"
  kb-incidents-rw-dev:     "<schema user password>"
  kb-wiki-rw-dev:          "<schema user password>"
  kb-code-rw-dev:          "<schema user password>"
  kb-fa-rw-dev:            "<schema user password>"
  kb-shim-rw-dev:          "<schema user password>"

  # ---- OpenAI direct (only needed if KBF_LLM_PROVIDER=openai_direct) ----
  openai-api-key:          "<sk-proj-... if running in openai_direct mode>"
  openai-org-id:           "<org-... optional>"
  openai-project-id:       "<proj_... optional>"

  # ---- Confluence ----
  confluence-readonly:     "<Confluence personal access token>"
  confluence-mcp-token:    "<MCP server token, only if confluence mode: mcp>"
  confluence-webhook-secret: "<HMAC shared secret for incoming webhooks>"

  # ---- Jira ----
  jira-readonly:           "<Jira personal access token>"
  jira-mcp-token:          "<MCP server token, only if jira mode: mcp>"
  jira-webhook-secret:     "<HMAC shared secret>"

  # ---- Git wiki repo ----
  git-readonly:            "<read-only deploy key or HTTPS token>"

  # ---- UDAP / Sentinel (Phase 2; safe to leave blank for Phase 1) ----
  udap-jdbc-url:           ""
  udap-user:               ""
  udap-password:           ""
