{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "framework/parsers/schemas/ops-mgr/incident-exec-summary/v1.json",
  "title": "Ops Manager — incident exec summary — v1",
  "type": "object",
  "required": ["incident_id", "severity", "customer_impact"],
  "properties": {
    "incident_id": { "type": "string" },
    "severity": { "type": "string", "enum": ["sev1","sev2","sev3","sev4","near-miss"] },
    "customer_impact": { "type": "string", "description": "What customers experienced.", "maxLength": 500 },
    "duration_minutes": { "type": "integer", "minimum": 0 },
    "tenants_affected_count": { "type": "integer", "minimum": 0 },
    "comms_posture": { "type": "string", "enum": ["public", "customer-direct", "internal-only"] },
    "follow_ups": { "type": "array", "items": { "type": "string" } },
    "ETA_to_resolution": { "type": "string", "description": "If still active." }
  },
  "additionalProperties": false
}
