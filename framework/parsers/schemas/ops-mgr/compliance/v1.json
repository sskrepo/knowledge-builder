{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "framework/parsers/schemas/ops-mgr/compliance/v1.json",
  "title": "Ops Manager — compliance posture — v1",
  "type": "object",
  "required": ["framework", "scope", "status"],
  "properties": {
    "framework": { "type": "string", "description": "SOC2 / ISO27001 / PCI / HIPAA / GDPR / etc." },
    "scope": { "type": "string", "description": "Service / region / tenant tier covered." },
    "status": { "type": "string", "enum": ["compliant", "in-progress", "exception", "non-compliant"] },
    "evidence_links": { "type": "array", "items": { "type": "string", "format": "uri" } },
    "next_audit": { "type": "string", "format": "date" },
    "open_findings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
